# Credenciais da API do Telegram (my.telegram.org) - Compartilhado entre bots
API_ID=1234567
API_HASH="0123456789abcdef0123456789abcdef"

# --- Tokens Específicos para Cada Bot ---

# Token para o bot principal (super_bot.py)
BOT_TOKEN="TOKEN_DO_SEU_BOT_PRINCIPAL"

# Token específico para o bot de comandos (comandos_bot.py)
# O código já está configurado para usar esta variável primeiro.
BOT_TOKEN_COMANDOS="TOKEN_DO_SEU_BOT_DE_COMANDOS"

# --- Configuração de Segurança para o Bot de Comandos ---

# Lista de IDs de conversa permitidos (separados por vírgula)
# Apenas estes usuários/grupos poderão interagir com os comandos de administração do bot de comandos.
# Use o comando /id no bot para descobrir o ID de uma conversa.
ALLOWED_CHAT_IDS="ID_DO_SEU_USUARIO,ID_DE_UM_GRUPO"
